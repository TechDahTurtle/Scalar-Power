{
  "multipart": [
    {   "apply": { "model": "scalarpower:block/copper_wire_center" }},
    {   "when": { "north": "true" },
      "apply": { "model": "scalarpower:block/copper_wire_side" }
    },
    {   "when": { "south": "true" },
      "apply": { "model": "scalarpower:block/copper_wire_side", "y": 180 }
    },
    {   "when": { "east": "true" },
      "apply": { "model": "scalarpower:block/copper_wire_side", "y": 90 }
    },
    {   "when": { "west": "true" },
      "apply": { "model": "scalarpower:block/copper_wire_side", "y": 270 }
    },
    {   "when": { "up": "true" },
      "apply": { "model": "scalarpower:block/copper_wire_side", "x": 270 }
    },
    {   "when": { "down": "true" },
      "apply": { "model": "scalarpower:block/copper_wire_side", "x": 90 }
    }
  ]
}